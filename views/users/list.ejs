<%- include('../partials/header') %>
<%- include('../partials/menu') %>

<main>
    <h2>Liste des utilisateurs</h2>
    <p><a href="/users-page/new" class="btn">Ajouter un utilisateur</a></p>

    <table>
        <thead>
            <tr>
                <th>Nom d'utilisateur</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(function (u) { %>
                <tr>
                    <td><%= u.username %></td>
                    <td><%= u.email %></td>
                    <td>
                        <a href="/users-page/<%= u.email %>">Voir</a>
                        <a href="/users-page/<%= u.email %>/edit">Modifier</a>
                        <form action="/users-page/<%= u.email %>/delete" method="POST" style="display:inline">
                            <button type="submit" onclick="return confirm('Supprimer cet utilisateur ?')">Supprimer</button>
                        </form>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</main>

<%- include('../partials/footer') %>
